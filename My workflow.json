    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Ambil nama proyek dari node awal dan deskripsi dari Gemini\nconst newProjectName = $('Code in JavaScript1').item.json.name;\nconst geminiData = JSON.parse($('Message a model').item.json.content.parts[0].text.replace(/```json/gi, '').replace(/```/gi, '').trim());\nconst newShortDesc = geminiData.short_description;\n\n// Baca isi README profil Anda (terjemahkan dari Base64)\nlet readmeContent = Buffer.from($input.item.json.content, 'base64').toString('utf8');\n\n// Cari area di antara penanda gaib\nconst startMarker = '`:`';\nconst endMarker = '`latest`';\nconst regex = new RegExp(`${startMarker}[\\\\s\\\\S]*?${endMarker}`);\nconst match = readmeContent.match(regex);\n\nif (match) {\n    // Bersihkan daftar proyek yang ada saat ini\n    let currentProjects = match[0]\n        .replace(startMarker, '')\n        .replace(endMarker, '')\n        .trim()\n        .split('\\n')\n        .filter(line => line.trim() !== '');\n\n    // Cegah duplikasi jika proyek yang sama di-sync ulang\n    currentProjects = currentProjects.filter(line => !line.includes(`**${newProjectName}**`));\n\n    // Siapkan teks baru\n    const newEntry = `- **${newProjectName}** : ${newShortDesc}`;\n\n    // Masukkan proyek baru di baris paling atas (LIFO)\n    currentProjects.unshift(newEntry);\n\n    // Potong array agar maksimal hanya berisi 4 item\n    currentProjects = currentProjects.slice(0, 4);\n\n    // Paksa semua item memiliki tepat 2 spasi di depannya\n    currentProjects = currentProjects.map(line => {\n        return `  ${line.trimStart()}`;\n    });\n\n    // Rakit kembali teksnya\n    const newSection = `${startMarker}\\n${currentProjects.join('\\n')}\\n${endMarker}`;\n\n    // Timpa isi README lama dengan yang baru\n    readmeContent = readmeContent.replace(regex, newSection);\n}\n\n// Kembalikan teks ke bentuk Base64 untuk dikirim kembali ke GitHub\nreturn {\n    updated_readme_base64: Buffer.from(readmeContent).toString('base64'),\n    commit_message: `Update recent projects: ${newProjectName}`\n};"
      },
